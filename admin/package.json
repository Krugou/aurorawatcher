{
  "name": "aurorawatcher-admin",
  "version": "1.0.0",
  "private": true,
  "main": "server/index.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host --port 3005",
    "build": "vite build client && tsc -p server/tsconfig.json",
    "start": "node dist/server/index.js",
    "test": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fs-extra": "^11.4.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-fs-backend": "^2.6.6",
    "i18next-http-backend": "^4.0.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-i18next": "^17.0.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.4",
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
